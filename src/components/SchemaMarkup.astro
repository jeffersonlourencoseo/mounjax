---
import { SITE_CONFIG } from '../data/config';

export interface Props {
  type: 'home' | 'product' | 'page' | 'faq' | 'article';
  title?: string;
  description?: string;
  image?: string;
  datePublished?: string;
  dateModified?: string;
  faqData?: Array<{ question: string; answer: string }>;
  breadcrumbs?: Array<{ name: string; url: string }>;
}

const {
  type,
  title = SITE_CONFIG.titleDefault,
  description = SITE_CONFIG.descriptionDefault,
  image = SITE_CONFIG.ogImage,
  datePublished = '2026-05-24',
  dateModified = '2026-05-24',
  faqData = [],
  breadcrumbs = [],
} = Astro.props;

const canonicalUrl = Astro.url.href;
const currentPath = Astro.url.pathname;

// Schema: Organization (E-E-A-T)
const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: SITE_CONFIG.siteName,
  alternateName: 'Blog Mounjax Review',
  url: SITE_CONFIG.domain,
  logo: `${SITE_CONFIG.domain}/images/logo.png`,
  sameAs: Object.values(SITE_CONFIG.social).filter(Boolean),
  contactPoint: {
    '@type': 'ContactPoint',
    email: SITE_CONFIG.author.email,
    contactType: 'customer support',
    areaServed: 'BR',
    availableLanguage: 'Portuguese',
  },
};

// Schema: WebSite (sem SearchAction)
const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: SITE_CONFIG.siteName,
  url: SITE_CONFIG.domain,
  description: SITE_CONFIG.tagline,
  publisher: {
    '@type': 'Organization',
    name: SITE_CONFIG.siteName,
    url: SITE_CONFIG.domain,
  },
};

// Schema: Product básico (sem AggregateRating e Review)
const productSchema = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: SITE_CONFIG.product.name,
  image: [image, SITE_CONFIG.product.image],
  description: 'Suplemento natural em gotas que auxilia na queima de gordura e controle do apetite.',
  brand: {
    '@type': 'Brand',
    name: SITE_CONFIG.product.name,
  },
  offers: {
    '@type': 'Offer',
    url: SITE_CONFIG.product.affiliateLink,
    price: SITE_CONFIG.product.price,
    priceCurrency: SITE_CONFIG.product.priceCurrency,
    availability: SITE_CONFIG.product.availability,
    priceValidUntil: '2026-12-31',
  },
};

// Schema: WebPage genérico
const webpageSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: title,
  url: canonicalUrl,
  description,
  image,
  datePublished,
  dateModified,
  author: {
    '@type': 'Organization',
    name: SITE_CONFIG.author.name,
    url: SITE_CONFIG.domain,
  },
  publisher: {
    '@type': 'Organization',
    name: SITE_CONFIG.siteName,
    url: SITE_CONFIG.domain,
  },
  isPartOf: {
    '@type': 'WebSite',
    name: SITE_CONFIG.siteName,
    url: SITE_CONFIG.domain,
  },
  inLanguage: SITE_CONFIG.language,
};

// Schema: Article para páginas de conteúdo
const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  url: canonicalUrl,
  image,
  datePublished,
  dateModified,
  author: {
    '@type': 'Organization',
    name: SITE_CONFIG.siteName,
    url: SITE_CONFIG.domain,
  },
  publisher: {
    '@type': 'Organization',
    name: SITE_CONFIG.siteName,
    url: SITE_CONFIG.domain,
    logo: {
      '@type': 'ImageObject',
      url: `${SITE_CONFIG.domain}/images/logo.png`,
    },
  },
};

// Schema: FAQPage
const faqSchema =
  faqData.length > 0
    ? {
        '@context': 'https://schema.org',
        '@type': 'FAQPage',
        mainEntity: faqData.map((faq) => ({
          '@type': 'Question',
          name: faq.question,
          acceptedAnswer: {
            '@type': 'Answer',
            text: faq.answer,
          },
        })),
      }
    : null;

// Schema: BreadcrumbList
const breadcrumbSchema = breadcrumbs.length > 0
  ? {
      '@context': 'https://schema.org',
      '@type': 'BreadcrumbList',
      itemListElement: [
        {
          '@type': 'ListItem',
          position: 1,
          name: 'Início',
          item: `${SITE_CONFIG.domain}/`,
        },
        ...breadcrumbs.map((crumb, index) => ({
          '@type': 'ListItem',
          position: index + 2,
          name: crumb.name,
          item: crumb.url,
        })),
      ],
    }
  : null;

const homeSchemas = [organizationSchema, websiteSchema, productSchema];
if (faqSchema) homeSchemas.push(faqSchema);

const schemas: Record<string, any[]> = {
  home: homeSchemas,
  product: [organizationSchema, webpageSchema, productSchema],
  page: [organizationSchema, webpageSchema],
  article: [organizationSchema, articleSchema],
  faq: faqSchema ? [organizationSchema, websiteSchema, faqSchema] : [organizationSchema, websiteSchema],
};

let activeSchemas = schemas[type] || schemas.page;
if (breadcrumbSchema) {
  activeSchemas = [...activeSchemas, breadcrumbSchema];
}
---

{
  activeSchemas.map((schema: any) => (
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  ))
}
