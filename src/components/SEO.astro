---
import { SITE_CONFIG } from '../data/config';

export interface Props {
  title: string;
  description: string;
  keywords?: string;
  image?: string;
  canonical?: string;
  noindex?: boolean;
  ogType?: string;
  ogAlt?: string;
  ogLocale?: string;
}

const {
  title,
  description,
  keywords = SITE_CONFIG.keywordsDefault,
  image = SITE_CONFIG.ogImage,
  canonical,
  noindex = false,
  ogType = 'website',
  ogAlt,
  ogLocale = SITE_CONFIG.locale,
} = Astro.props;

const canonicalUrl = canonical ?? (SITE_CONFIG.domain + Astro.url.pathname);
const pageTitle = title.includes(SITE_CONFIG.siteName)
  ? title
  : `${title} | ${SITE_CONFIG.siteName}`;

const currentPath = Astro.url.pathname;

const ogAltTexts: Record<string, string> = {
  '/': 'Mounjax Review — Análise Completa do Suplemento',
  '/o-que-e/': 'O que é o Mounjax — Suplemento Natural em Gotas',
  '/composicao/': 'Composição do Mounjax — 9 Ingredientes Naturais',
  '/beneficios/': 'Benefícios do Mounjax — Queima de Gordura e Saciedade',
  '/como-usar/': 'Como Usar Mounjax — 12 Gotas por Dia',
  '/contraindicacoes/': 'Contraindicações do Mounjax',
  '/onde-comprar/': 'Onde Comprar Mounjax Original com Desconto',
  '/depoimentos/': 'Depoimentos de Quem Usou Mounjax',
  '/sobre-nos/': 'Sobre o Blog Mounjax',
  '/contato/': 'Contato — Blog Mounjax',
};

const resolvedOgAlt = ogAlt ?? ogAltTexts[currentPath] ?? `Imagem de destaque: ${pageTitle}`;

const articleSlugs = ['/o-que-e/', '/composicao/', '/beneficios/', '/como-usar/', '/contraindicacoes/'];
const isArticle = ogType === 'article' || articleSlugs.includes(currentPath);
const publishedTime = '2026-05-24';
const modifiedTime = '2026-05-24';
---

<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<meta name="generator" content={Astro.generator} />

<!-- Título e Meta Básicas -->
<title>{pageTitle}</title>
<meta name="description" content={description} />
<meta name="author" content={SITE_CONFIG.author.name} />
<meta name="robots" content={noindex ? 'noindex, follow' : 'index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1'} />
<meta name="googlebot" content={noindex ? 'noindex, follow' : 'index, follow'} />

<!-- Canonical -->
<link rel="canonical" href={canonicalUrl} />

<!-- Favicon -->
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="icon" href="/favicon.ico" />
<link rel="apple-touch-icon" href="/apple-touch-icon.png" />
<meta name="theme-color" content={SITE_CONFIG.themeColor} />

<!-- Preconnect Performance -->
<link rel="preconnect" href={SITE_CONFIG.domain} />
<link rel="dns-prefetch" href={SITE_CONFIG.domain} />

<!-- Open Graph (Facebook / LinkedIn / WhatsApp) -->
<meta property="og:title" content={pageTitle} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonicalUrl} />
<meta property="og:site_name" content={SITE_CONFIG.siteName} />
<meta property="og:image" content={image} />
<meta property="og:image:alt" content={resolvedOgAlt} />
<meta property="og:type" content={isArticle ? 'article' : ogType} />
<meta property="og:locale" content={ogLocale} />

<!-- Twitter Cards -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={pageTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={image} />
<meta name="twitter:image:alt" content={resolvedOgAlt} />

<!-- Artigo específico (somente quando ogType === 'article' ou página de conteúdo) -->
{isArticle && (
  <>
    <meta property="article:published_time" content={publishedTime} />
    <meta property="article:modified_time" content={modifiedTime} />
    <meta property="article:author" content={SITE_CONFIG.author.name} />
    <meta property="article:publisher" content={SITE_CONFIG.domain} />
    <meta property="article:section" content="Saúde e Suplementação" />
  </>
)}

<!-- Google Tag Manager -->
<script is:inline src="https://www.googletagmanager.com/gtag/js?id=G-XXXXXXXXXX"></script>
<script is:inline>
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  gtag('js', new Date());
  gtag('config', 'G-XXXXXXXXXX');
</script>

<!-- Event tracking para cliques em afiliado -->
<script is:inline>
  document.addEventListener('DOMContentLoaded', function() {
    document.body.addEventListener('click', function(e) {
      var el = e.target.closest('a');
      if (!el) return;
      var href = el.getAttribute('href') || '';
      if (href.indexOf('app.monetizze.com.br/r/ATX25785612') > -1) {
        var location = 'generic';
        if (el.closest('#onde-comprar')) location = 'onde-comprar';
        else if (el.closest('footer')) location = 'footer';
        else if (el.closest('section#o-que-e')) location = 'o-que-e';
        else if (document.querySelector('section.relative.min-h-\[90vh\]') && el.closest('section.relative.min-h-\[90vh\]')) location = 'cta-hero';
        else if (document.querySelector('main') && el.closest('main')) location = 'homepage';
        if (typeof gtag === 'function') {
          gtag('event', 'click_afiliado', { location: location });
        }
      }
    });
  });
</script>
