---
const navItems = [
  { label: "Início", href: "/" },
  { label: "O que é", href: "/o-que-e/" },
  { label: "Composição", href: "/composicao/" },
  { label: "Benefícios", href: "/beneficios/" },
  { label: "Como Usar", href: "/como-usar/" },
  { label: "Contraindicações", href: "/contraindicacoes/" },
  { label: "Depoimentos", href: "/depoimentos/" },
  { label: "Onde Comprar", href: "/onde-comprar/" },
];

const currentPath = Astro.url.pathname;
---

<nav class="fixed top-0 left-0 right-0 z-50 bg-surface/95 backdrop-blur-md border-b border-brand/5">
  <div class="container mx-auto px-6 lg:px-12">
    <div class="flex items-center justify-between h-[72px]">
      <a href="/" class="flex flex-col leading-none">
        <span class="font-display text-2xl font-bold text-brand tracking-tight">Mounjax</span>
        <span class="text-[0.65rem] font-semibold text-accent uppercase tracking-[0.15em] mt-0.5">Review</span>
      </a>

      <!-- Mobile: link simples para página do menu -->
      <a href="/menu/" class="lg:hidden flex flex-col items-center justify-center w-12 h-12 gap-[6px]" aria-label="Abrir menu">
        <span class="block w-6 h-[2px] bg-brand"></span>
        <span class="block w-6 h-[2px] bg-brand"></span>
        <span class="block w-6 h-[2px] bg-brand"></span>
      </a>

      <!-- Desktop: menu horizontal -->
      <ul class="hidden lg:flex items-center gap-8 list-none m-0 p-0">
        {navItems.map(item => (
          <li>
            <a
              href={item.href}
              class={`text-sm font-medium transition-colors hover:text-brand ${currentPath === item.href ? 'text-brand' : 'text-brand-dark/90'}`}
            >
              {item.label}
            </a>
          </li>
        ))}
        <li>
          <a href="/onde-comprar/" class="inline-flex items-center gap-2 text-xs font-semibold uppercase tracking-wider text-white bg-gradient-to-r from-brand to-brand-light px-5 py-2.5 rounded-full hover:shadow-lg hover:-translate-y-0.5 transition-all">
            Oferta Especial
          </a>
        </li>
      </ul>
    </div>
  </div>
</nav>
