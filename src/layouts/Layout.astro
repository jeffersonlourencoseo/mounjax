---
import SEO from '../components/SEO.astro';
import SchemaMarkup from '../components/SchemaMarkup.astro';

export interface Props {
  title: string;
  description: string;
  keywords?: string;
  image?: string;
  canonical?: string;
  noindex?: boolean;
  ogType?: string;
  ogAlt?: string;
  schemaType?: 'home' | 'product' | 'page' | 'faq' | 'article';
  schemaTitle?: string;
  schemaDesc?: string;
  schemaImage?: string;
  schemaFaq?: Array<{ question: string; answer: string }>;
  breadcrumbs?: Array<{ name: string; url: string }>;
  schemaHowTo?: Array<{ name: string; text: string; image?: string }>;
}

const {
  title,
  description,
  keywords,
  image,
  canonical,
  noindex = false,
  ogType = 'website',
  ogAlt,
  schemaType = 'page',
  schemaTitle,
  schemaDesc,
  schemaImage,
  schemaFaq,
  breadcrumbs,
  schemaHowTo,
} = Astro.props;
---

<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <SEO
    title={title}
    description={description}
    keywords={keywords}
    image={image}
    canonical={canonical}
    noindex={noindex}
    ogType={ogType}
    ogAlt={ogAlt}
  />

  <!-- CSS crítico inline: previne CLS enquanto o Tailwind carrega de forma async -->
  <style is:inline>
    *,*::before,*::after{box-sizing:border-box}
    body{margin:0;line-height:1.5}
    nav{display:block}
    a{color:inherit;text-decoration:inherit}
    button{cursor:pointer;background-color:transparent;background-image:none}
    .fixed{position:fixed}
    .absolute{position:absolute}
    .relative{position:relative}
    .top-0{top:0}
    .left-0{left:0}
    .right-0{right:0}
    .bottom-0{bottom:0}
    .z-50{z-index:50}
    .z-\[60\]{z-index:60}
    .container{width:100%;margin-left:auto;margin-right:auto;padding-left:1.5rem;padding-right:1.5rem}
    .mx-auto{margin-left:auto;margin-right:auto}
    .flex{display:flex}
    .hidden{display:none}
    .items-center{align-items:center}
    .justify-between{justify-content:space-between}
    .h-\[72px\]{height:72px}
    .pt-\[72px\]{padding-top:72px}
    .w-12{width:3rem}
    .h-12{height:3rem}
    .sr-only{position:absolute;width:1px;height:1px;padding:0;margin:-1px;overflow:hidden;clip:rect(0,0,0,0);white-space:nowrap;border-width:0}
    .sr-only:focus{position:static;width:auto;height:auto;padding:0;margin:0;overflow:visible;clip:auto;white-space:normal}
    @media(min-width:1024px){
      .lg\:px-12{padding-left:3rem;padding-right:3rem}
      .lg\:flex{display:flex}
      .lg\:hidden{display:none}
    }
  </style>

  <style is:global>
    html {
      scroll-behavior: smooth;
      scroll-padding-top: 88px;
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
    }

    ::selection {
      background-color: #513F7E;
      color: #fff;
    }

    body {
      /* System fonts apenas — elimina CLS causado por web fonts */
      font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
    }

    h1, h2, h3, h4 {
      font-family: Georgia, 'Times New Roman', serif;
      text-wrap: balance;
    }

    @media (prefers-reduced-motion: reduce) {
      html {
        scroll-behavior: auto;
      }
      *, *::before, *::after {
        animation-duration: 0.01ms !important;
        animation-iteration-count: 1 !important;
        transition-duration: 0.01ms !important;
      }
    }

    /* Garante áreas de toque mínimas em links e botões */
    a, button {
      min-height: 44px;
      min-width: 44px;
    }
  </style>
</head>

<body class="bg-surface text-brand-dark antialiased">
  <slot />

  <!-- CTA Sticky Mobile -->
  <div class="fixed bottom-0 left-0 right-0 bg-white border-t border-brand/10 p-3 z-50 lg:hidden shadow-[0_-4px_20px_rgba(0,0,0,0.1)]">
    <a href="https://app.monetizze.com.br/r/ATX25785612"
       target="_blank"
       class="flex items-center justify-center gap-2 text-sm font-bold uppercase tracking-wider text-white bg-brand w-full py-3 rounded-full"
       rel="noopener noreferrer nofollow sponsored"
    >
      Comprar com Desconto
    </a>
  </div>

  <!-- Schema JSON-LD — movido para o final do body para não bloquear renderização -->
  <SchemaMarkup
    type={schemaType}
    title={schemaTitle || title}
    description={schemaDesc || description}
    image={schemaImage || image}
    faqData={schemaFaq}
    breadcrumbs={breadcrumbs}
    howToData={schemaHowTo}
  />

  <!-- GTag carregado sob demanda após interação ou após 8s — evita JS não usado no primeiro paint -->
  <script is:inline>
    (function() {
      var loaded = false;
      function loadGtag() {
        if (loaded) return;
        loaded = true;
        var s = document.createElement('script');
        s.src = 'https://www.googletagmanager.com/gtag/js?id=G-44Y4HNY57K';
        s.async = true;
        s.defer = true;
        s.fetchPriority = 'low';
        document.head.appendChild(s);
      }
      window.addEventListener('scroll', loadGtag, { once: true, passive: true });
      window.addEventListener('click', loadGtag, { once: true, passive: true });
      window.addEventListener('keydown', loadGtag, { once: true, passive: true });
      window.addEventListener('touchstart', loadGtag, { once: true, passive: true });
      setTimeout(loadGtag, 8000);
    })();
  </script>

  <!-- Event tracking para cliques em afiliado -->
  <script is:inline>
    document.body.addEventListener('click', function(e) {
      var el = e.target.closest('a[href*="app.monetizze.com.br/r/ATX25785612"]');
      if (!el) return;
      var location = 'generic';
      if (el.closest('#onde-comprar')) location = 'onde-comprar';
      else if (el.closest('footer')) location = 'footer';
      else if (el.closest('section#o-que-e')) location = 'o-que-e';
      else if (el.closest('section.relative.min-h-\[90vh\]')) location = 'cta-hero';
      else if (el.closest('main')) location = 'homepage';
      if (typeof gtag === 'function') {
        gtag('event', 'click_afiliado', { location: location });
      }
    });
  </script>
</body>
</html>
