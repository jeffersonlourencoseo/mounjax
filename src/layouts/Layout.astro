---
import SEO from '../components/SEO.astro';
import SchemaMarkup from '../components/SchemaMarkup.astro';

export interface Props {
  title: string;
  description: string;
  keywords?: string;
  image?: string;
  canonical?: string;
  noindex?: boolean;
  ogType?: string;
  ogAlt?: string;
  schemaType?: 'home' | 'product' | 'page' | 'faq' | 'article';
  schemaTitle?: string;
  schemaDesc?: string;
  schemaImage?: string;
  schemaFaq?: Array<{ question: string; answer: string }>;
  breadcrumbs?: Array<{ name: string; url: string }>;
  schemaHowTo?: Array<{ name: string; text: string; image?: string }>;
}

const {
  title,
  description,
  keywords,
  image,
  canonical,
  noindex = false,
  ogType = 'website',
  ogAlt,
  schemaType = 'page',
  schemaTitle,
  schemaDesc,
  schemaImage,
  schemaFaq,
  breadcrumbs,
  schemaHowTo,
} = Astro.props;
---

<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <SEO
    title={title}
    description={description}
    keywords={keywords}
    image={image}
    canonical={canonical}
    noindex={noindex}
    ogType={ogType}
    ogAlt={ogAlt}
  />

  <style is:global>
    html {
      scroll-behavior: smooth;
      scroll-padding-top: 88px;
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
    }

    ::selection {
      background-color: #513F7E;
      color: #fff;
    }

    body {
      /* System fonts apenas — elimina CLS causado por web fonts */
      font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
    }

    h1, h2, h3, h4 {
      font-family: Georgia, 'Times New Roman', serif;
      text-wrap: balance;
    }

    @media (prefers-reduced-motion: reduce) {
      html {
        scroll-behavior: auto;
      }
      *, *::before, *::after {
        animation-duration: 0.01ms !important;
        animation-iteration-count: 1 !important;
        transition-duration: 0.01ms !important;
      }
    }

    /* Garante áreas de toque mínimas em links e botões */
    a, button {
      min-height: 44px;
      min-width: 44px;
    }

    /* Reserva espaço para o CTA sticky mobile e evita CLS */
    body {
      padding-bottom: 80px;
    }
    @media (min-width: 1024px) {
      body {
        padding-bottom: 0;
      }
    }
  </style>
</head>

<body class="bg-surface text-brand-dark antialiased">
  <slot />

  <!-- CTA Sticky Mobile: altura fixa e posição reservada para evitar CLS -->
  <div
    class="fixed bottom-0 left-0 right-0 bg-white border-t border-brand/10 p-3 z-50 lg:hidden shadow-[0_-4px_20px_rgba(0,0,0,0.1)]"
    aria-label="Oferta mobile"
    role="complementary"
    style="height: 80px;"
  >
    <a href="https://app.monetizze.com.br/r/ATX25785612"
       target="_blank"
       class="flex items-center justify-center gap-2 text-sm font-bold uppercase tracking-wider text-white bg-brand w-full h-14 rounded-full"
       rel="noopener noreferrer nofollow sponsored"
       aria-label="Comprar Mounjax com desconto no site oficial"
    >
      Comprar com Desconto
    </a>
  </div>

  <!-- Schema JSON-LD — movido para o final do body para não bloquear renderização -->
  <SchemaMarkup
    type={schemaType}
    title={schemaTitle || title}
    description={schemaDesc || description}
    image={schemaImage || image}
    faqData={schemaFaq}
    breadcrumbs={breadcrumbs}
    howToData={schemaHowTo}
  />
</body>
</html>
