---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Contato | Mounjax Review"
  description="Entre em contato com a equipe do Mounjax Review."
  schemaType="page"
>
  <Navigation />

  <main class="pt-[72px]">
    <section class="py-24 lg:py-32">
      <div class="container mx-auto px-6 lg:px-12 max-w-4xl">
        <!-- Breadcrumb -->
        <nav aria-label="Navegação" class="mb-8">
          <ol class="flex items-center gap-2 text-sm text-brand-dark/50 list-none m-0 p-0">
            <li>
              <a href="/" class="inline-flex items-center gap-1 hover:text-brand transition-colors">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
                </svg>
                Início
              </a>
            </li>
            <li class="text-brand-dark/30">/</li>
            <li class="text-brand-dark font-medium" aria-current="page">Contato</li>
          </ol>
        </nav>

        <h1 class="font-display text-5xl md:text-6xl font-bold text-brand-dark leading-tight mb-10">Contato</h1>

        <div class="prose prose-lg max-w-none">
          <p class="text-lg text-brand-dark/70 leading-relaxed mb-6">
            Tem dúvidas, sugestões ou quer falar com nossa equipe? Entre em contato conosco.
          </p>

          <div class="bg-surface-alt p-8 rounded-2xl border border-brand/5 mt-12">
            <h2 class="font-display text-2xl font-bold text-brand-dark mb-6">Informações de Contato</h2>

            <div class="space-y-4">
              <div>
                <span class="text-sm font-semibold text-brand-dark/50 uppercase tracking-wider">Email</span>
                <p class="text-brand-dark">contato@mounjax-review.com</p>
              </div>

              <div>
                <span class="text-sm font-semibold text-brand-dark/50 uppercase tracking-wider">Horário de Atendimento</span>
                <p class="text-brand-dark">Segunda a Sexta, das 9h às 18h (horário de Brasília)</p>
              </div>

              <div>
                <span class="text-sm font-semibold text-brand-dark/50 uppercase tracking-wider">Resposta</span>
                <p class="text-brand-dark">Responderemos em até 48 horas úteis.</p>
              </div>
            </div>
          </div>

          <p class="text-brand-dark/50 text-sm mt-10">
            Para questões sobre pedidos, entregas ou reembolso do produto, entre em contato diretamente com o suporte oficial da Nutryme no site oficial.
          </p>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
