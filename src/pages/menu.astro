---
const navItems = [
  { label: "Início", href: "/", icon: "home" },
  { label: "O que é", href: "/o-que-e/", icon: "info" },
  { label: "Composição", href: "/composicao/", icon: "flask" },
  { label: "Benefícios", href: "/beneficios/", icon: "heart" },
  { label: "Como Usar", href: "/como-usar/", icon: "droplet" },
  { label: "Contraindicações", href: "/contraindicacoes/", icon: "alert" },
  { label: "Depoimentos", href: "/depoimentos/", icon: "message" },
  { label: "Onde Comprar", href: "/onde-comprar/", icon: "shopping" },
];

import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Menu — Blog Mounjax"
  description="Navegue por todas as páginas do Blog Mounjax."
  noindex={true}
>
  <main id="conteudo-principal" class="min-h-screen bg-surface pt-[72px] pb-24">
    <div class="container mx-auto px-6 py-12 max-w-md">
      <a href="/" class="inline-flex items-center gap-2 text-sm font-medium text-brand mb-8 hover:underline">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
        </svg>
        Voltar para o site
      </a>

      <h1 class="font-display text-3xl font-bold text-brand-dark mb-8">Menu</h1>

      <nav aria-label="Menu mobile">
      <ul class="flex flex-col gap-3 list-none m-0 p-0" role="menu">
        {navItems.map(item => (
          <li>
            <a
              href={item.href}
              class="flex items-center gap-4 py-4 px-4 text-lg font-medium text-brand-dark/80 bg-surface-alt rounded-lg hover:text-brand hover:bg-brand/5 transition-colors"
            >
              {item.icon === "home" && (
                <svg class="w-5 h-5 text-brand flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-4 0V16a1 1 0 011-1h2a1 1 0 011 1v4"/></svg>
              )}
              {item.icon === "info" && (
                <svg class="w-5 h-5 text-brand flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 18h.01M12 14a4 4 0 014-4h0a4 4 0 014 4v6H8v-6a4 4 0 014-4h0zM8 14v-2a4 4 0 014-4h0a4 4 0 014 4v2"/></svg>
              )}
              {item.icon === "flask" && (
                <svg class="w-5 h-5 text-brand flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9.75 3.104v5.714a2 2 0 01-.659 1.473L5 14.5l.752 1.5H18.25l.752-1.5-4.091-4.209a2 2 0 01-.659-1.473V3.104a2.25 2.25 0 00-1.7-2.179 63 63 0 00-1.5-.121 63 63 0 00-1.5.121 2.25 2.25 0 00-1.7 2.179z"/></svg>
              )}
              {item.icon === "heart" && (
                <svg class="w-5 h-5 text-brand flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z"/></svg>
              )}
              {item.icon === "droplet" && (
                <svg class="w-5 h-5 text-brand flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 11.25l-3-3m0 0l-3 3m3-3v7.5M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              )}
              {item.icon === "alert" && (
                <svg class="w-5 h-5 text-brand flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z"/></svg>
              )}
              {item.icon === "message" && (
                <svg class="w-5 h-5 text-brand flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M7.5 8.25h9m-9 3H12m-9.75 1.51c0 1.6 1.123 2.994 2.707 3.227 1.087.16 2.185.283 3.293.369V21l4.075-4.075c.684-.684 1.537-1.073 2.453-1.123.92-.05 1.81.233 2.594.808 1.163.858 1.884 2.153 1.884 3.54V6.375c0-1.036-.84-1.875-1.875-1.875h-15A1.875 1.875 0 003 6.375V16.5z"/></svg>
              )}
              {item.icon === "shopping" && (
                <svg class="w-5 h-5 text-brand flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 3h1.386c.51 0 .955.343 1.087.835l.383 1.437M7.5 14.25a3 3 0 00-3 3h15.75m-17.25-3h16.5a1.5 1.5 0 001.5-1.5v-6a1.5 1.5 0 00-1.5-1.5H5.625a1.5 1.5 0 00-1.5 1.5v6a1.5 1.5 0 001.5 1.5zm3-9v6m0 0l-1.5-1.5m1.5 1.5l1.5-1.5"/></svg>
              )}
              <span>{item.label}</span>
            </a>
          </li>
        ))}
        <li class="mt-4">
          <a
            href="/onde-comprar/"
            class="flex items-center justify-center gap-2 text-sm font-semibold uppercase tracking-wider text-white bg-gradient-to-r from-brand to-brand-light px-6 py-4 rounded-full"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 10.5V6a3.75 3.75 0 10-7.5 0v4.5m11.356-1.993l1.263 12c.07.665-.45 1.243-1.119 1.243H4.25a1.125 1.125 0 01-1.12-1.243l1.264-12A1.125 1.125 0 015.513 7.5h12.974c.576 0 1.059.435 1.119 1.007z"/></svg>
            Oferta Especial
          </a>
        </li>
      </ul>
      </nav>
    </div>
  </main>
</Layout>
