---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';

export async function getStaticPaths() {
  const pages = await getCollection('pages');
  return pages.map((page) => ({
    params: { slug: page.slug },
    props: { page },
  }));
}

const { page } = Astro.props;
const { Content } = await page.render();

const articleSlugs = ['o-que-e', 'composicao', 'beneficios', 'como-usar', 'contraindicacoes'];
const isArticle = articleSlugs.includes(page.slug);
const schemaType = isArticle ? 'article' : 'page';

const breadcrumbs = [{ name: page.data.title, url: `https://blogmounjax.com.br/${page.slug}/` }];
---

<Layout
  title={`${page.data.title} | Mounjax Review`}
  description={page.data.description}
  keywords={page.data.keywords}
  image={`https://blogmounjax.com.br/images/og-${page.slug}.jpg`}
  schemaType={schemaType}
  schemaTitle={page.data.title}
  schemaDesc={page.data.description}
  schemaImage={`https://blogmounjax.com.br/images/og-${page.slug}.jpg`}
  breadcrumbs={breadcrumbs}
>
  <Navigation />

  <main class="pt-[72px]">
    <section class="py-24 lg:py-32">
      <div class="container mx-auto px-6 lg:px-12 max-w-4xl">
        <!-- Breadcrumb -->
        <nav aria-label="Navegação" class="mb-8">
          <ol class="flex items-center gap-2 text-sm text-brand-dark/50 list-none m-0 p-0">
            <li>
              <a href="/" class="inline-flex items-center gap-1 hover:text-brand transition-colors">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
                </svg>
                Início
              </a>
            </li>
            <li class="text-brand-dark/30">/</li>
            <li class="text-brand-dark font-medium" aria-current="page">{page.data.title}</li>
          </ol>
        </nav>

        {page.slug === 'o-que-e' && (
          <div class="bg-warning-bg border border-warning/20 p-4 rounded-xl mb-8">
            <p class="text-sm text-brand-dark/80 leading-relaxed">
              <strong>Aviso importante:</strong> Este site é um review independente. O Mounjax é um suplemento alimentar, não um medicamento. Os resultados podem variar de pessoa para pessoa. Consulte um médico antes de iniciar qualquer tratamento.
            </p>
          </div>
        )}

        <article class="prose prose-lg max-w-none">
          <Content />
        </article>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
